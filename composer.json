{
    "name": "hexters/maillens",
    "description": "Catch outgoing mail during local development and read it in the browser at /mail. Set MAIL_MAILER=fake and every email your Laravel app sends is stored instead of delivered.",
    "keywords": ["laravel", "php", "mail", "email", "mailer", "smtp", "mailtrap", "mailpit", "mailcatcher", "dev-tools", "local-development", "email-preview", "email-testing"],
    "license": "MIT",
    "authors": [
        {
            "name": "Asep SS",
            "email": "hexters@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Hexters\\MailLens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hexters\\MailLens\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hexters\\MailLens\\MailLensServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
